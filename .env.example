# SYMBA T4.6 — example environment variables for the production compose
# (docker-compose.prod.yml). Copy to .env in the deploy directory and
# adjust as needed.

# Public port to expose the app on the host. Default: 8088.
SYMBA_PUBLIC_PORT=8088

# CORS origins (comma-separated, no spaces). Leave empty to use the
# defaults baked into app/main.py (localhost dev ports). For a public
# deployment behind a reverse proxy, set this to your domain(s):
#   BACKEND_CORS_ORIGINS=https://symba.example.eu,https://www.symba.example.eu
BACKEND_CORS_ORIGINS=

# (Optional) SQLite database URL override. Default points to
# /app/backend/data/app.db inside the container. Mount a volume there
# (compose does this by default) for persistence.
# SYMBA_DB_URL=sqlite:////app/backend/data/app.db
